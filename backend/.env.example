# ── Database ──────────────────────────────────────────────
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=groupevents;Username=groupevents;Password=groupevents_dev

# ── JWT ───────────────────────────────────────────────────
Jwt__Secret=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
Jwt__Issuer=group-event-management
Jwt__Audience=group-event-management-clients
Jwt__AccessTokenExpiryMinutes=15
Jwt__RefreshTokenExpiryDays=30

# ── OAuth ─────────────────────────────────────────────────
OAuth__Google__ClientId=YOUR_GOOGLE_CLIENT_ID
OAuth__Apple__ClientId=YOUR_APPLE_CLIENT_ID
OAuth__Apple__TeamId=YOUR_APPLE_TEAM_ID
OAuth__Apple__KeyId=YOUR_APPLE_KEY_ID

# ── Push notifications (Firebase) ─────────────────────────
Fcm__ProjectId=YOUR_FIREBASE_PROJECT_ID
Fcm__CredentialsJson={"type":"service_account",...}

# ── Email (Resend) ────────────────────────────────────────
Resend__ApiKey=re_YOUR_RESEND_API_KEY
Resend__FromAddress=noreply@yourdomain.com

# ── Hangfire ──────────────────────────────────────────────
# Uses the same connection string by default

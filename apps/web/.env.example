# Backend API base URL
VITE_API_BASE_URL=http://localhost:5189/api

# Google Identity Services
# Obtain from: https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Apple Sign In
# Obtain from: https://developer.apple.com → Certificates, Identifiers & Profiles → Services IDs
VITE_APPLE_CLIENT_ID=com.your-company.gem
VITE_APPLE_REDIRECT_URI=https://your-domain.com/auth/apple/callback

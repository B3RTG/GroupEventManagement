# ── Backend API ────────────────────────────────────────────
# URL base del backend. Las variables EXPO_PUBLIC_* se exponen al bundle de cliente.
#
# Emulador Android (acceso al host):
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:5189/api/v1
#
# Simulador iOS / dispositivo físico en la misma red:
#   EXPO_PUBLIC_API_URL=http://192.168.x.x:5189/api/v1
#
# Producción:
#   EXPO_PUBLIC_API_URL=https://api.tu-dominio.com/api/v1
EXPO_PUBLIC_API_URL=http://localhost:5189/api/v1

# ── Google OAuth ────────────────────────────────────────────
# Obtener en: https://console.cloud.google.com → APIs & Services → Credentials
#
# Web Client ID (usado también como fallback):
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# iOS Client ID (OAuth 2.0 para app iOS nativa — dev build):
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Android Client ID (OAuth 2.0 para app Android nativa — dev build):
# Crear en Google Cloud Console → tipo "Android"
# Package name: com.groupeventmanagement.app
# SHA-1: obtener con `eas credentials` o `keytool`
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# ── Apple Sign In ───────────────────────────────────────────
# Solo disponible en iOS 13+. No requiere variables de entorno en la app mobile;
# la configuración se hace en app.json (bundleIdentifier) y en el portal de Apple Developer.
# Referencia: https://developer.apple.com → Certificates, Identifiers & Profiles → App IDs
